gorenel.site {
    log # Bağlantı detaylarını görmek için loglamayı açtık

    # API yolları
    handle /api/* {
        reverse_proxy gorenel-server:9091
    }
    handle /health {
        reverse_proxy gorenel-server:9091
    }
    handle /metrics {
        reverse_proxy gorenel-server:9091
    }
    handle /info {
        reverse_proxy gorenel-server:9091
    }

    # Kurulum dosyaları
    handle /install.sh {
        reverse_proxy gorenel-server:9091
    }
    handle /install.ps1 {
        reverse_proxy gorenel-server:9091
    }
    handle /downloads/* {
        reverse_proxy gorenel-server:9091
    }

    handle /tunnel/connect {
        reverse_proxy gorenel-server:9091 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up Connection "Upgrade"
            header_up Upgrade "websocket"
        }
    }

    # Gerisi Dashboard (React)
    handle {
        reverse_proxy gorenel-dashboard:80
    }
}

# Main Site & API
gorenel.site {
    log

    # API yolları
    handle /api/* {
        reverse_proxy gorenel-server:9091
    }
    handle /health {
        reverse_proxy gorenel-server:9091
    }
    handle /metrics {
        reverse_proxy gorenel-server:9091
    }
    handle /info {
        reverse_proxy gorenel-server:9091
    }

    # Kurulum dosyaları
    handle /install.sh {
        reverse_proxy gorenel-server:9091
    }
    handle /install.ps1 {
        reverse_proxy gorenel-server:9091
    }
    handle /downloads/* {
        reverse_proxy gorenel-server:9091
    }

    handle /tunnel/connect {
        reverse_proxy gorenel-server:9091
    }

    # Dashboard (React)
    handle {
        reverse_proxy gorenel-dashboard:80
    }
}

# Dynamic Tunnels (subdomains)
*.gorenel.site {
    tls {
        on_demand
    }
    reverse_proxy gorenel-server:8085
}

{
    email bekircan3634@gmail.com
    debug
    on_demand_tls {
        ask http://gorenel-server:9091/api/tls/ask
    }
}

# Main Site & API
gorenel.site {
    log {
        output file /var/log/caddy/access.log
    }

    # API yolları
    handle /api/* {
        reverse_proxy gorenel-server:9091
    }
    handle /health {
        reverse_proxy gorenel-server:9091
    }
    handle /metrics {
        reverse_proxy gorenel-server:9091
    }
    handle /info {
        reverse_proxy gorenel-server:9091
    }

    # Kurulum dosyaları
    handle /install.sh {
        reverse_proxy gorenel-server:9091
    }
    handle /install.ps1 {
        reverse_proxy gorenel-server:9091
    }
    handle /downloads/* {
        reverse_proxy gorenel-server:9091
    }

    handle /tunnel/connect {
        reverse_proxy gorenel-server:9091
    }

    # Dashboard (React)
    handle {
        reverse_proxy gorenel-dashboard:80
    }
}

# Dynamic Tunnels (subdomains)
# Using a more explicit site label for subdomains to ensure matching correctly
https://*.gorenel.site {
    tls {
        on_demand
    }
    
    log {
        output file /var/log/caddy/subdomains.log
    }

    reverse_proxy gorenel-server:8085
}

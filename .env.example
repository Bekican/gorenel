# Gorenel Backend - Environment Variables
# Copy this file to .env and fill in your values

# General
GO_ENV=production
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
PROXY_PORT=:8085
CONTROL_PORT=:7000
MONITOR_PORT=:9091

# Database
DB_URL=postgres://postgres:postgres@localhost:5432/gorenel?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# ClickHouse
CLICKHOUSE_ADDR=localhost:9001
CLICKHOUSE_DB=gorenel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ML Engine
ML_URL=http://localhost:5000

# Domain & SSL
BASE_DOMAIN=.gorenel.net
ACME_EMAIL=admin@gorenel.net

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://yourdomain.com/api/v1/auth/google/callback

# Iyzico Payment
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
